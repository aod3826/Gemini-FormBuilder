function createSheetWithHeaders(schema) {
  try {
    if (!schema || !schema.fields || !schema.targetSheetName) {
      throw new Error("Invalid schema or missing target sheet name");
    }

    const validFields = schema.fields.filter((field) => field.name && field.name.trim());
    if (validFields.length === 0) {
      throw new Error("No valid fields found in schema. Each field must have a name.");
    }

    const ss = SpreadsheetApp.getActiveSpreadsheet();
    let sheet = ss.getSheetByName(schema.targetSheetName);

    const headers = ["id"];
    if (!sheet) {
      sheet = ss.insertSheet(schema.targetSheetName);
    }
    validFields.forEach((field) => {
      headers.push(field.name.trim());
    });
    sheet.getRange(1, 1, 1, headers.length).setValues([headers]);
  } catch (error) {
    Logger.log("Error creating sheet with headers: " + error.toString());
    throw new Error("Failed to create sheet with headers: " + error.toString());
  }
}

function saveApplicationSchemaToSheet(schema) {
  try {
    const ss = SpreadsheetApp.getActiveSpreadsheet();
    const sheetName = "Application Schemas";

    let sheet = ss.getSheetByName(sheetName);
    if (!sheet) {
      sheet = ss.insertSheet(sheetName);
      const headers = ["Created_Date", "Application Name", "Schema"];
      sheet.getRange(1, 1, 1, headers.length).setValues([headers]);
    }

    const createdDate = new Date();
    const applicationName = schema.applicationName || "Unnamed Application";
    const schemaString = JSON.stringify(schema);

    // Check if application name already exists
    const data = sheet.getDataRange().getValues();
    const headers = data[0];
    const appNameColumnIndex = headers.indexOf("Application Name");

    if (appNameColumnIndex === -1) {
      throw new Error("Application Name column not found");
    }

    // Find existing row with same application name
    let existingRowIndex = -1;
    for (let i = 1; i < data.length; i++) {
      if (data[i][appNameColumnIndex] === applicationName) {
        existingRowIndex = i + 1; // +1 because sheet rows are 1-indexed
        break;
      }
    }

    const values = [createdDate, applicationName, schemaString];

    if (existingRowIndex > 0) {
      // Update existing row
      sheet.getRange(existingRowIndex, 1, 1, values.length).setValues([values]);
      Logger.log(`Application schema updated for: ${applicationName}`);
    } else {
      // Add new row
      sheet.appendRow(values);
      Logger.log(`New application schema saved for: ${applicationName}`);
    }

    return JSON.stringify([...data, values]);
  } catch (error) {
    Logger.log("Error saving application schema to sheet: " + error.toString());
    throw new Error("Failed to save application schema to sheet: " + error.toString());
  }
}

