function doGet(e) {
  const pages = {
    index: "CRUD Application",
    formbuilder: "Gemini Form Builder",
    unauthorized: "Access Denied",
  };

  // Determine requested page and enforce owner-only access for formbuilder
  let pageKey = "index";
  if (e && e.parameter && e.parameter.p === "formbuilder") {
     pageKey = isSpreadsheetOwner() ? "formbuilder" : "unauthorized";
    // pageKey = isSpreadsheetOwner() ? "formbuilder" : "formbuilder";
  }

  const page = pageKey === "formbuilder" ? "Frontend/index.html" : pageKey === "unauthorized" ? "Frontend/unauthorized.html" : "Frontend/userIndex.html";

  Logger.log("Loading page: " + page);
  var t = HtmlService.createTemplateFromFile(page);
  return t.evaluate().setTitle(pages[pageKey]);
}

function isSpreadsheetOwner() {
  try {
    const ss = SpreadsheetApp.getActiveSpreadsheet();
    const file = DriveApp.getFileById(ss.getId());
    const ownerEmail = file.getOwner().getEmail();
    const userEmail = Session.getActiveUser().getEmail();
    return userEmail && ownerEmail && userEmail.toLowerCase() === ownerEmail.toLowerCase();
  } catch (error) {
    Logger.log("Ownership check failed: " + error.toString());
    return false;
  }
}
