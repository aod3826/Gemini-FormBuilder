function JSONToArray(jsonArray) {
  var header = [];
  for (const [k, v] of Object.entries(jsonArray[0])) {
    header.push(k);
  }
  return jsonArray.map((r) => {
    const a = [];
    for (let i = 0; i < header.length; ++i) {
      a.push(r[header[i]]);
    }
    return a;
  });
}

