function deleteApplicationSchemaByName(applicationName) {
  try {
    const ss = SpreadsheetApp.getActiveSpreadsheet();
    const sheetName = "Application Schemas";

    let sheet = ss.getSheetByName(sheetName);
    if (!sheet) {
      Logger.log("Application Schemas sheet not found");
      return false;
    }

    const data = sheet.getDataRange().getValues();
    if (data.length <= 1) {
      Logger.log("No schemas found in Application Schemas sheet");
      return false;
    }

    const headers = data[0];
    const appNameColumnIndex = headers.indexOf("Application Name");

    if (appNameColumnIndex === -1) {
      throw new Error("Application Name column not found");
    }

    // Find row with matching application name
    let rowToDelete = -1;
    for (let i = 1; i < data.length; i++) {
      if (data[i][appNameColumnIndex] === applicationName) {
        rowToDelete = i + 1; // +1 because sheet rows are 1-indexed
        break;
      }
    }

    if (rowToDelete === -1) {
      Logger.log(`Application schema not found: ${applicationName}`);
      return false;
    }

    // Delete the row
    sheet.deleteRow(rowToDelete);
    Logger.log(`Application schema deleted: ${applicationName}`);
    return true;
  } catch (error) {
    Logger.log("Error deleting application schema: " + error.toString());
    throw new Error("Failed to delete application schema: " + error.toString());
  }
}

function getAllSheetData() {
