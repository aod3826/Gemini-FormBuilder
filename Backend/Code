function getApplicationSchema() {
  try {
    // First try to get from Script Properties (legacy)
    const properties = PropertiesService.getScriptProperties();
    const legacySchema = properties.getProperty("APPLICATION_SCHEMA");
    if (legacySchema) {
      return JSON.parse(legacySchema);
    }

    // If no legacy schema, try to get the most recent one from the sheet
    const ss = SpreadsheetApp.getActiveSpreadsheet();
    const sheetName = "Application Schemas";

    let sheet = ss.getSheetByName(sheetName);
    if (!sheet) {
      Logger.log("Application Schemas sheet not found");
      return null;
    }

    const data = sheet.getDataRange().getValues();
    if (data.length <= 1) {
      Logger.log("No schemas found in Application Schemas sheet");
      return null;
    }

    // Get the most recent schema (last row)
    const lastRow = data[data.length - 1];
    const schemaString = lastRow[2]; // Schema column is index 2

    if (schemaString) {
      return JSON.parse(schemaString);
    }

    return null;
  } catch (error) {
    Logger.log("Error loading latest form schema: " + error.toString());
    throw new Error("Failed to load form schema: " + error.toString());
  }
}

function getApplicationSchemaByName(applicationName) {
  try {
    const ss = SpreadsheetApp.getActiveSpreadsheet();
    const sheetName = "Application Schemas";

    let sheet = ss.getSheetByName(sheetName);
    if (!sheet) {
      Logger.log("Application Schemas sheet not found");
      return null;
    }

    const data = sheet.getDataRange().getValues();
    if (data.length <= 1) {
      Logger.log("No schemas found in Application Schemas sheet");
      return null;
    }

    const headers = data[0];
    const appNameColumnIndex = headers.indexOf("Application Name");

    if (appNameColumnIndex === -1) {
      throw new Error("Application Name column not found");
    }

    // Find the row with the specified application name
    for (let i = 1; i < data.length; i++) {
      if (data[i][appNameColumnIndex] === applicationName) {
        const schemaString = data[i][2]; // Schema column is index 2
        if (schemaString) {
          return JSON.parse(schemaString);
        }
        break;
      }
    }

    return null;
  } catch (error) {
    Logger.log("Error loading schema by name: " + error.toString());
    throw new Error("Failed to load schema by name: " + error.toString());
  }
}

