  }
}

/**
 * Check if Gemini API key is configured
 */
function checkGeminiApiKey() {
  try {
    const apiKey = getApiKey();
    if (apiKey) {
      Logger.log("✅ Gemini API key is configured");
      Logger.log("API Key length: " + apiKey.length);
      Logger.log("First 10 characters: " + apiKey.substring(0, 10) + "...");
      return {
        configured: true,
        length: apiKey.length,
        preview: apiKey.substring(0, 10) + "...",
      };
    } else {
      Logger.log("❌ No Gemini API key found");
      return {
        configured: false,
        message: "Please set the Gemini API key using the Form Builder menu",
      };
    }
  } catch (error) {
    Logger.log("❌ Error checking API key: " + error.toString());
    return {
      configured: false,
      error: error.toString(),
    };
  }
}

/**
 * Test GeminiService instantiation via Library
 */
function testGeminiServiceInstantiation() {
  try {
    Logger.log("🧪 Testing GeminiService instantiation...");

    const apiKeyCheck = checkGeminiApiKey();
    if (!apiKeyCheck.configured) {
      Logger.log("❌ Cannot test service - no API key configured");
      return apiKeyCheck;
    }

    Logger.log("Creating GeminiService instance...");
    const geminiService = getGeminiServiceInstance();

    Logger.log("✅ Service instantiated successfully");
    Logger.log("Service status: " + JSON.stringify(geminiService.getStatus(), null, 2));

    return {
      success: true,
      message: "Service instantiated successfully",
      status: geminiService.getStatus(),
    };
  } catch (error) {
    Logger.log("❌ Failed to instantiate GeminiService: " + error.toString());
    Logger.log("Error stack: " + error.stack);
    return {
      success: false,
      error: error.toString(),
      stack: error.stack,
    };
  }
}
