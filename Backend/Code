  const sheetData = {};
  sheets.forEach((sheet) => {
    if (sheet.getName() !== "Application Schemas") {
      sheetData[sheet.getName()] = sheet.getDataRange().getValues();
    }
  });
  return JSON.stringify(sheetData);
}

const executeAction = ({ action, sheetName, id = null, data = null, headers = null }) => {
  let res = null;
  try {
    if (!sheetName) {
      const schema = getApplicationSchema();
      if (!schema) {
        throw new Error("No schema found");
      }
      sheetName = schema.targetSheetName;
    }

    const orm = new ORM(sheetName, headers);

    switch (action) {
      case "add":
        res = orm.create(data);

        break;
      case "update":
        res = orm.updateById(id, data);

        break;
      case "delete":
        res = orm.deleteById(id);

        break;
      case "getAll":
        res = orm.readAll();
        break;
      case "getOne":
        res = orm.readById(id);
        break;
      default:
        return false;
    }

    return JSON.stringify(res);
  } catch (error) {
    console.log(error);
    return error;
  }
};

function uploadFile(obj) {
  var blob = Utilities.newBlob(Utilities.base64Decode(obj.data), obj.mimeType, obj.fileName);
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var SSID = ss.getId();
  var fileInDrive = DriveApp.getFolderById(SSID);
  var parent_id = fileInDrive.getParents().next().getId();
  var par_fdr = DriveApp.getFolderById(parent_id);
  try {
    var newFdr = par_fdr.getFoldersByName(FOLDER_NAME).next();
  } catch (e) {
    var newFdr = par_fdr.createFolder(FOLDER_NAME);
  }

  var id = newFdr.createFile(blob).getId();
  const url = obj.mimeType.includes("image") ? `https://drive.google.com/thumbnail?id=${id}&sz=w1000` : `https://drive.google.com/file/d/${id}/view?usp=sharing`;
  return { name: obj.fileName, url, uid: obj.uid };
}

// ===== GEMINI CHAT SERVICE INTEGRATION (using Library) =====

/**
 * Helper to create a GeminiService instance
 */
function getGeminiServiceInstance() {
  const apiKey = getApiKey(); // assumes you already have this helper
  if (!apiKey) {
    throw new Error("No Gemini API key configured. Please set it first.");
  }
  return GeminiService.GeminiService(apiKey); // from the library
}

/**
 * Test Gemini API connection
 */
function testGeminiConnection() {
  try {
    const geminiService = getGeminiServiceInstance();
    const result = geminiService.testConnection();

    if (result.success) {
      Logger.log("Gemini connection test successful");
      return {
        success: true,
        message: result.message,
        testSchema: result.testSchema,
      };
    } else {
      Logger.log("Gemini connection test failed: " + result.error);
      return {
        success: false,
        error: result.error,
      };
    }
  } catch (error) {
    Logger.log("Error testing Gemini connection: " + error.toString());
    return {
      success: false,
      error: "Connection test failed: " + error.toString(),
    };
  }
}

/**
 * Send message to Gemini and get form schema
 */
function sendMessageToGemini(userPrompt, previousResponse = null) {
  try {
    const geminiService = getGeminiServiceInstance();
    const result = geminiService.sendMessage(userPrompt, previousResponse);

    if (result.success) {
      Logger.log("Gemini message sent successfully");
      return {
        success: true,
        schema: result.schema,
        message: result.message,
      };
    } else {
      Logger.log("Gemini message failed: " + result.error);
      return {
        success: false,
        error: result.error,
        details: result.details,
      };
    }
  } catch (error) {
    Logger.log("Error sending message to Gemini: " + error.toString());
    return {
      success: false,
      error: "Failed to send message: " + error.toString(),
    };
  }
}

/**
 * Get Gemini service status
