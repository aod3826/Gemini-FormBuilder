function saveFormSubmission(formData, schemaId) {
  try {
    const ss = SpreadsheetApp.getActiveSpreadsheet();
    const sheetName = `Form_${schemaId}`;

    let sheet = ss.getSheetByName(sheetName);
    if (!sheet) {
      sheet = ss.insertSheet(sheetName);
      const headers = ["Timestamp", "Submission ID", ...Object.keys(formData)];
      sheet.getRange(1, 1, 1, headers.length).setValues([headers]);
    }

    const submissionId = Utilities.getUuid();
    const timestamp = new Date();
    const values = [timestamp, submissionId, ...Object.values(formData)];

    sheet.appendRow(values);

    Logger.log("Form submission saved successfully");
    return true;
  } catch (error) {
    Logger.log("Error saving form submission: " + error.toString());
    throw new Error("Failed to save form submission: " + error.toString());
  }
}

