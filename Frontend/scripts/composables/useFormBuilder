          },
          {
            name: "step",
            label: "Step",
            dataType: "number",
            htmlType: "number",
            placeholder: "1",
          },
        ],
      },
      {
        type: "textarea",
        label: "Textarea",
        icon: "mdi mdi-text",
        defaultProps: {
          placeholder: "Enter text...",
          required: false,
          rows: 3,
        },
        attributes: [
          {
            name: "rows",
            label: "Rows",
            dataType: "number",
            htmlType: "number",
            placeholder: "3",
          },
          {
            name: "minLength",
            label: "Min Length",
            dataType: "number",
            htmlType: "number",
          },
          {
            name: "maxLength",
            label: "Max Length",
            dataType: "number",
            htmlType: "number",
          },
        ],
      },
      {
        type: "select",
        label: "Dropdown",
        icon: "mdi mdi-menu-down",
        defaultProps: {
          placeholder: "Select an option...",
          required: false,
          options_string: "Option 1\nOption 2",
        },
        attributes: [
          {
            name: "options_string",
            label: "Options",
            dataType: "options_string",
            placeholder: "Option 1\nOption 2\nOption 3",
          },
          {
            name: "multiple",
            label: "Allow Multiple Selection",
            dataType: "boolean",
          },
        ],
      },
      {
        type: "radio",
        label: "Radio Group",
        icon: "mdi mdi-radiobox-marked",
        defaultProps: {
          required: false,
          options_string: "Option 1\nOption 2",
        },
        attributes: [
          {
            name: "options_string",
            label: "Options",
            dataType: "options_string",
            placeholder: "Option 1\nOption 2\nOption 3",
          },
        ],
      },
      {
        type: "checkbox",
        label: "Checkbox",
        icon: "mdi mdi-checkbox-marked",
        defaultProps: {
          required: false,
          options_string: "Option 1\nOption 2",
        },
        attributes: [
          {
            name: "options_string",
            label: "Options",
            dataType: "options_string",
            placeholder: "Option 1\nOption 2\nOption 3",
          },
        ],
      },
      {
        type: "date",
        label: "Date Picker",
        icon: "mdi mdi-calendar",
        htmlInputType: "date",
        defaultProps: {
          placeholder: "Select date...",
          required: false,
        },
        attributes: [
          {
            name: "min",
            label: "Min Date",
            dataType: "string",
            htmlType: "date",
          },
          {
            name: "max",
            label: "Max Date",
            dataType: "string",
            htmlType: "date",
          },
          {
            name: "locale",
            label: "Locale (for JS pickers)",
            dataType: "string",
            htmlType: "text",
            placeholder: "en-US",
          },
          {
            name: "dateFormat",
            label: "Date Format (for JS pickers)",
            dataType: "string",
            htmlType: "text",
            placeholder: "MM/dd/yyyy",
          },
        ],
      },
      {
        type: "file",
        label: "File Upload",
        icon: "mdi mdi-file-upload",
        defaultProps: {
          required: false,
          accept: "*",
        },
        attributes: [],
      },
      {
        type: "image",
        label: "Image Upload",
        icon: "mdi mdi-image",
        defaultProps: {
          required: false,
          accept: "*",
        },
        attributes: [],
      },
      {
        type: "link",
        label: "Link",
        icon: "mdi mdi-link",
        defaultProps: {
          required: false,
          placeholder: "Enter url...",
        },
        attributes: [],
      },
      {
        type: "customPrice",
        label: "Price Input",
        icon: "mdi mdi-currency-usd",
        htmlInputType: "number",
        defaultProps: {
          placeholder: "Enter price...",
          required: false,
          step: "0.01",
          currency: "USD",
          locale: "en-US",
          currencyPosition: "prefix",
        },
        attributes: [
          {
            name: "min",
            label: "Min Price",
            dataType: "number",
            htmlType: "number",
          },
          {
            name: "max",
            label: "Max Price",
            dataType: "number",
            htmlType: "number",
          },
          {
            name: "step",
            label: "Step",
            dataType: "number",
            htmlType: "number",
            placeholder: "0.01",
          },
          {
            name: "currency",
            label: "Currency Code",
            dataType: "string",
            htmlType: "text",
            placeholder: "USD",
          },
          {
            name: "locale",
            label: "Locale (for formatting)",
            dataType: "string",
            htmlType: "text",
            placeholder: "en-US",
          },
          {
            name: "currencyPosition",
            label: "Currency Symbol Position",
            dataType: "select_string",
            values: ["prefix", "suffix"],
          },
        ],
      },
      {
        type: "phone",
        label: "Phone Number",
        icon: "mdi mdi-phone",
        htmlInputType: "tel",
        defaultProps: {
          placeholder: "Enter phone number...",
          required: false,
        },
        attributes: [
          {
            name: "pattern",
            label: "Pattern (Regex)",
            dataType: "string",
            htmlType: "text",
            placeholder: "^\\+?[0-9]{7,15}$",
          },
          {
            name: "minLength",
            label: "Min Length",
            dataType: "number",
            htmlType: "number",
          },
          {
            name: "maxLength",
            label: "Max Length",
            dataType: "number",
            htmlType: "number",
          },
        ],
      },
      {
        type: "toggle",
        label: "Toggle Switch",
        icon: "mdi mdi-toggle-switch",
        defaultProps: {
          required: false,
          checked: false,
        },
        attributes: [
          {
            name: "checked",
            label: "Default Checked",
            dataType: "boolean",
          },
        ],
      },
    ]);

    // Computed properties
    const selectedFieldTypeObject = computed(() => {
      if (!editingField.value || !editingField.value.type) {
        return null;
      }
      return fieldTypes.value.find((ft) => ft.type === editingField.value.type);
    });

    const defaultValueInputType = computed(() => {
      if (!editingField.value || !editingField.value.type) return "text";
      const fieldTypeDef = fieldTypes.value.find((f) => f.type === editingField.value.type);
      return fieldTypeDef?.htmlInputType || "text";
    });

    // Enhanced Methods
    const addField = (fieldType) => {
      const fieldTypeObj = typeof fieldType === "string" ? fieldTypes.value.find((ft) => ft.type === fieldType) : fieldType;

      if (fieldTypeObj) {
        const newField = {
          id: nextFieldId.value++,
          type: fieldTypeObj.type,
          name: `field_${formFields.value.length + 1}`,
          label: fieldTypeObj.label,
          ...fieldTypeObj.defaultProps,
        };

        formFields.value.push(newField);
      }
    };

    const removeField = (index) => {
      ElMessageBox.confirm("Are you sure you want to delete this field?", "Confirm", {
        confirmButtonText: "OK",
        cancelButtonText: "Cancel",
        type: "warning",
      })
        .then(() => {
          formFields.value.splice(index, 1);
          ElMessage.success("Field deleted successfully");
        })
        .catch(() => {
          // User cancelled
        });
    };

    const editField = (field, index) => {
      editingField.value = JSON.parse(JSON.stringify(field));
      editingIndex.value = index;
      showEditModal.value = true;
    };

    const saveFieldEdit = async () => {
      isEditing.value = true;

      try {
        // Validate required fields
        if (!editingField.value.name) {
          ElMessage.error("Please enter a unique Name/Key for the field.");
          return;
        }

        // Check for duplicate name/key if not editing the same field
        const isNameDuplicate = formFields.value.some((field, index) => field.name === editingField.value.name && index !== editingIndex.value);
        if (isNameDuplicate) {
          ElMessage.error(`The Name/Key "${editingField.value.name}" is already in use. Please choose a unique one.`);
          return;
        }

        // Update the field directly - no parsing needed
        formFields.value[editingIndex.value] = JSON.parse(JSON.stringify(editingField.value));
        cancelEdit();

        ElMessage.success("Field updated successfully!");
      } finally {
        isEditing.value = false;
      }
    };

    const cancelEdit = () => {
      showEditModal.value = false;
      editingField.value = null;
      editingIndex.value = -1;
    };

    const clearForm = () => {
      ElMessageBox.confirm("Are you sure you want to clear all fields? This will reset the form builder.", "Confirm", {
        confirmButtonText: "OK",
        cancelButtonText: "Cancel",
        type: "warning",
      })
        .then(() => {
          formFields.value = [];
          formName.value = "Untitled Form";
          // Reset enhanced settings to defaults
          applicationName.value = "Dynamic Form Application";
          targetSheetName.value = "Form_Data";
          currency.value = "USD";
          locale.value = "en-US";
          ElMessage.success("Form builder cleared successfully");
        })
        .catch(() => {
          // User cancelled
        });
    };

    // Field type change handler
    const onFieldTypeChange = () => {
      // Keep common properties
      const commonAttrs = {
        type: editingField.value.type,
        name: editingField.value.name || "",
        label: editingField.value.label || "",
        placeholder: editingField.value.placeholder || "",
        defaultValue: editingField.value.defaultValue || "",
        helperText: editingField.value.helperText || "",
        required: !!editingField.value.required,
      };

      // Reset to common properties
      editingField.value = { ...commonAttrs };

      // Initialize type-specific attributes with defaults
      const fieldTypeDef = selectedFieldTypeObject.value;
      if (fieldTypeDef && fieldTypeDef.attributes) {
        fieldTypeDef.attributes.forEach((attr) => {
          if (attr.dataType === "boolean") {
            editingField.value[attr.name] = false;
          } else if (attr.dataType === "options_string") {
            editingField.value[attr.name] = "Option 1\nOption 2";
          } else {
            editingField.value[attr.name] = "";
          }
        });
      }
    };

    // Drag and drop methods
    const onDragStart = (event, fieldType) => {
      console.log("🚀 Drag start:", fieldType);
      event.dataTransfer.setData("text/plain", JSON.stringify(fieldType));
      event.dataTransfer.effectAllowed = "copy";
    };

    const onDragOver = (event) => {
      event.preventDefault();
      dragOver.value = true;
    };

    const onDragLeave = () => {
      dragOver.value = false;
    };

    const onDrop = (event) => {
      console.log("📥 Drop event triggered");
      event.preventDefault();
      dragOver.value = false;

      try {
        const fieldType = JSON.parse(event.dataTransfer.getData("text/plain"));
        console.log("📥 Parsed field type:", fieldType);
        addField(fieldType);
      } catch (error) {
        console.error("Error parsing dropped data:", error);
      }
    };

    // Load schema data into form builder
    const loadSchemaData = (schema) => {
      formName.value = schema.name;

      // Load enhanced settings if available
      if (schema.applicationName) {
        applicationName.value = schema.applicationName;
      }
      if (schema.targetSheetName) {
        targetSheetName.value = schema.targetSheetName;
      }
      if (schema.currency) {
        currency.value = schema.currency;
      }
      if (schema.locale) {
        locale.value = schema.locale;
      }

      formFields.value = schema.fields.map((field, index) => ({
        id: nextFieldId.value++,
        ...field,
      }));
    };

    return {
      // State
      formFields,
      nextFieldId,
      dragOver,
      showEditModal,
      editingField,
      editingIndex,
      isEditing,
      fieldTypes,
      formName,
      applicationName,
      targetSheetName,
      currency,
      locale,

      // Computed
      selectedFieldTypeObject,
      defaultValueInputType,

      // Methods
      addField,
      removeField,
      editField,
      saveFieldEdit,
      cancelEdit,
      clearForm,
      onDragStart,
      onDragOver,
      onDragLeave,
      onDrop,
      loadSchemaData,
      onFieldTypeChange,
    };
  };
</script>
