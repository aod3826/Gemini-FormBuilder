  // useFormBuilder.js - Enhanced Form Builder Composable
  const useFormBuilder = () => {
    // Reactive state
    const formFields = ref([]);
    const nextFieldId = ref(1);
    const dragOver = ref(false);
    const showEditModal = ref(false);
    const editingField = ref(null);
    const editingIndex = ref(-1);
    const isEditing = ref(false); // Loading state for field editing operations

    // Application-specific state
    const formName = ref("Untitled Form");
    const applicationName = ref("XYZ Application");
    const targetSheetName = ref("Form_Data");
    const currency = ref("USD");
    const locale = ref("en-US");

    const fieldTypes = ref([
      {
        type: "text",
        label: "Text Input",
        icon: "mdi mdi-form-textbox",
        htmlInputType: "text",
        defaultProps: {
          placeholder: "Enter text...",
          required: false,
        },
        attributes: [
          {
            name: "minLength",
            label: "Min Length",
            dataType: "number",
            htmlType: "number",
          },
          {
            name: "maxLength",
            label: "Max Length",
            dataType: "number",
            htmlType: "number",
          },
          {
            name: "pattern",
            label: "Pattern (Regex)",
            dataType: "string",
            htmlType: "text",
            placeholder: "^[A-Za-z]+$",
          },
        ],
      },
      {
        type: "email",
        label: "Email",
        icon: "mdi mdi-email",
        htmlInputType: "email",
        defaultProps: {
          placeholder: "Enter email...",
          required: false,
        },
        attributes: [
          {
            name: "minLength",
            label: "Min Length",
            dataType: "number",
            htmlType: "number",
          },
          {
            name: "maxLength",
            label: "Max Length",
            dataType: "number",
            htmlType: "number",
          },
          {
            name: "pattern",
            label: "Pattern (Regex)",
            dataType: "string",
            htmlType: "text",
            placeholder: "^[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Za-z]{2,}$",
          },
        ],
      },
      {
        type: "password",
        label: "Password",
        icon: "mdi mdi-lock",
        htmlInputType: "password",
        defaultProps: {
          placeholder: "Enter password...",
          required: false,
        },
        attributes: [
          {
            name: "minLength",
            label: "Min Length",
            dataType: "number",
            htmlType: "number",
          },
          {
            name: "maxLength",
            label: "Max Length",
            dataType: "number",
            htmlType: "number",
          },
          {
            name: "pattern",
            label: "Pattern (Regex)",
            dataType: "string",
            htmlType: "text",
            placeholder: "^(?=.*[A-Za-z])(?=.*\\d)[A-Za-z\\d@$!%*#?&]{8,}$",
          },
        ],
      },
      {
        type: "number",
        label: "Number",
        icon: "mdi mdi-numeric",
        htmlInputType: "number",
        defaultProps: {
          placeholder: "Enter number...",
          required: false,
        },
        attributes: [
          {
            name: "min",
            label: "Min Value",
            dataType: "number",
            htmlType: "number",
          },
          {
